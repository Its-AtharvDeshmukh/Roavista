<%- layout("/layouts/boilerplate") %>

<div class="premium-bg pb-5" style="min-height: 85vh;">
    <div class="container px-3 px-lg-5">
        
        <% if(myListings.length > 0) { %>
            <div class="row align-items-center pt-5 mb-5 animate-fade-in-up">
                <div class="col-md-7 mb-4 mb-md-0 text-center text-md-start">
                    <p class="gallery-title mb-2">Host Dashboard</p>
                    <p class="text-muted m-0">You are currently managing <strong><%= myListings.length %></strong> exclusive listings.</p>
                </div>
                <div class="col-md-5 text-center text-md-end">
                    <a href="/listings/new" class="ci-btn-reserve text-decoration-none px-4 py-2 d-inline-block shadow-sm">
                        <i class="fa-solid fa-plus-circle me-2"></i> Host New listings
                    </a>
                </div>
            </div>

            <div class="row g-3 g-md-4 mb-5 animate-fade-in-up">
                <div class="col-12 col-md-4">
                    <div class="stat-glass-card p-3 d-flex align-items-center gap-3 bg-white shadow-sm h-100">
                        <div class="stat-icon flex-shrink-0"><i class="fa-solid fa-house-circle-check"></i></div>
                        <div class="stat-content overflow-hidden">
                            <small class="stat-label d-block">TOTAL LISTINGS</small>
                            <h4 class="stat-value m-0 text-truncate"><%= myListings.length %></h4>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="stat-glass-card p-3 d-flex align-items-center gap-3 bg-white shadow-sm h-100">
                        <div class="stat-icon flex-shrink-0"><i class="fa-solid fa-bolt text-warning"></i></div>
                        <div class="stat-content overflow-hidden">
                            <small class="stat-label d-block">PAYOUT STATUS</small>
                            <h4 class="stat-value m-0 text-truncate">Direct-to-UPI</h4>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="stat-glass-card p-3 d-flex align-items-center gap-3 bg-white shadow-sm h-100">
                        <div class="stat-icon flex-shrink-0"><i class="fa-solid fa-shield-halved text-success"></i></div>
                        <div class="stat-content overflow-hidden">
                            <small class="stat-label d-block">HOST RANK</small>
                            <h4 class="stat-value m-0 text-truncate">Verified Platinum</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <% myListings.forEach((listing, index) => { %>
                    <div class="col-12 col-md-6 col-lg-4 animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s">
                        <div class="creative-info-card shadow-premium p-3 h-100 bg-white">
                            
                            <div class="position-relative overflow-hidden rounded-4 mb-3" style="height: 220px;">
                                <span class="booking-badge">
                                    <span class="sm-pulse me-2"></span> ACTIVE
                                </span>
                    
                                <% if (listing.images && listing.images.length > 0) { %>
                                    <img src="<%= listing.images[0].url %>" class="w-100 h-100 object-fit-cover hover-scale" alt="<%= listing.title %>">
                                <% } else { %>
                                    <img src="https://images.unsplash.com/photo-1499793983690-e29da59ef1c2" class="w-100 h-100 object-fit-cover hover-scale" alt="Default">
                                <% } %>
                            </div>

                            <div class="px-2">
                                <div class="d-flex justify-content-between align-items-start mb-1 gap-2">
                                    <h5 class="fw-bold m-0 text-truncate" style="max-width: 70%;"><%= listing.title %></h5>
                                    <span class="listing-id-tag">#<%= listing._id.toString().slice(-5).toUpperCase() %></span>
                                </div>
                                <p class="text-muted small mb-3"><i class="fa-solid fa-location-dot me-1"></i> <%= listing.location %></p>

                                <div class="date-info-box d-flex mb-3 overflow-hidden">
                                    <div class="flex-grow-1 text-center border-end px-2" style="min-width: 0;">
                                        <small class="d-block text-uppercase extra-small fw-bold text-muted mb-1">Price / Night</small>
                                        <span class="fw-bold d-block text-truncate">₹<%= listing.price.toLocaleString("en-IN") %></span>
                                    </div>
                                    <div class="flex-grow-1 text-center px-2" style="min-width: 0;">
                                        <small class="d-block text-uppercase extra-small fw-bold text-muted mb-1">Payout UPI</small>
                                        <span class="fw-bold text-truncate d-block"><%= listing.upiId || 'Not Set' %></span>
                                    </div>
                                </div>

                                <div class="d-flex gap-2 mb-3">
                                    <a href="/listings/<%= listing._id %>/edit" class="btn-action-light flex-grow-1 py-2 text-decoration-none text-center">
                                        <i class="fa-regular fa-pen-to-square me-1"></i> Edit
                                    </a>
                                    <a href="/listings/<%= listing._id %>" class="btn-action-dark flex-grow-1 py-2 text-decoration-none text-center">
                                        <i class="fa-regular fa-eye me-1"></i> View
                                    </a>
                                </div>

                                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" class="text-center border-top pt-2">
                                    <button class="btn btn-link text-danger text-decoration-none extra-small fw-bold p-0 border-0 bg-transparent" 
                                             onclick="return confirm('Permanently remove this sanctuary?')">
                                        REMOVE Listings
                                     </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

        <% } else { %>
            <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
                <div class="col-md-6 text-center animate-fade-in-up px-4">
                    <div class="empty-state-box p-5 mx-auto shadow-sm">
                        <div class="mb-4">
                            <i class="fa-solid fa-hotel text-muted" style="font-size: 4rem; opacity: 0.2;"></i>
                        </div>
                        <h4 class="fw-bold">Your Portfolio is Empty</h4>
                        <p class="text-muted">Start your hosting journey by listing your first extraordinary property.</p>
                        <a href="/listings/new" class="ci-btn-reserve px-4 py-2 text-decoration-none d-inline-block mt-2">Create First Listing</a>
                    </div>
                </div>
            </div>
        <% } %>

    </div>
</div>

<style>
/* --- CORE STYLING --- */
.premium-bg { background-color: #fdfdfd; font-family: 'Manrope', sans-serif; }
.gallery-title { font-family: 'Playfair Display', serif; font-weight: 500; color: #111; }

/* --- CARDS & STATS --- */
.creative-info-card { border-radius: 24px; border: 1px solid #f0f0f0; transition: all 0.3s ease; }
.creative-info-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08) !important; }

.stat-glass-card { border-radius: 20px; border: 1px solid #eee; transition: 0.3s; }
.stat-icon { width: 45px; height: 45px; background: #f8f9fa; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.stat-label { font-size: 0.65rem; font-weight: 800; color: #bbb; letter-spacing: 1px; }
.stat-value { font-size: 1.2rem; font-weight: 800; color: #111; }

/* --- OVERLAP FIXES --- */
.date-info-box { background: #f9f9f9; border-radius: 14px; padding: 12px 0; border: 1px solid #f2eee9; }
.extra-small { font-size: 0.62rem; letter-spacing: 0.8px; line-height: 1.2; }
.listing-id-tag { color: #D38B5D; font-size: 0.75rem; font-weight: 800; flex-shrink: 0; }

/* --- BUTTONS & BADGES --- */
.ci-btn-reserve, .btn-action-dark { background: #1a1a1a; color: #fff; border-radius: 50px; font-weight: 700; border: none; transition: 0.3s; }
.ci-btn-reserve:hover, .btn-action-dark:hover { background: #D38B5D; color: #fff; }

.btn-action-light { background: #f0f0f0; color: #111; border-radius: 50px; font-weight: 700; font-size: 0.85rem; }
.btn-action-light:hover { background: #e0e0e0; }

.booking-badge { position: absolute; top: 15px; left: 15px; background: rgba(255, 255, 255, 0.95); padding: 6px 14px; border-radius: 50px; font-size: 0.7rem; font-weight: 800; z-index: 5; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
.sm-pulse { width: 7px; height: 7px; background: #28a745; border-radius: 50%; animation: pulse-green 2s infinite; display: inline-block; }

@keyframes pulse-green { 0% { box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.7); } 70% { box-shadow: 0 0 0 8px rgba(40, 167, 69, 0); } 100% { box-shadow: 0 0 0 0 rgba(40, 167, 69, 0); } }
.hover-scale { transition: 0.6s ease; }
.creative-info-card:hover .hover-scale { transform: scale(1.08); }

.empty-state-box { border-radius: 30px; border: 2px dashed #ddd; background: #fff; }

@media (max-width: 767px) {
    .gallery-title { font-size: 2rem; }
    .stat-value { font-size: 1.1rem; }
    .btn-action-light, .btn-action-dark { font-size: 0.75rem; }
}
</style>