<%- layout("/layouts/boilerplate") %>

<div class="premium-bg pb-5" style="min-height: 85vh;">
<div class="container px-lg-5">

    <div class="pt-5 pb-4 text-center animate-fade-in-up">
        <h1 class="gallery-title mb-2">Your Listings</h1>
        <p class="text-muted">Experience the art of refined travel.</p>
    </div>

    <ul class="nav nav-pills mb-5 justify-content-center custom-pills" id="pills-tab" role="tablist">
       <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#upcoming">Upcoming Stays</button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#past">Past Memories</button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="upcoming">
            <div class="row g-4">
               <% if (userBookings && userBookings.length > 0) { %>
                   <% for(let booking of userBookings) { 
                        if (!booking.listing) continue; 
                        let today = new Date();
                        let diffTime = booking.checkIn - today;
                        let diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                   %>
                    <div class="col-lg-4 col-md-6 animate-fade-in-up">
                        <div class="creative-info-card shadow-premium p-3 h-100" style="border-radius: 24px;">
                            
                            <div class="position-relative overflow-hidden rounded-4 mb-3" style="height: 200px;">
                                <% if(diffDays > 0) { %>
                                    <span class="booking-badge"><i class="fa-regular fa-clock me-1"></i> In <%= diffDays %> days</span>
                                <% } else { %>
                                    <span class="booking-badge bg-success text-white"><i class="fa-solid fa-person-walking-luggage me-1"></i> Ongoing</span>
                                <% } %>
                    
                                <% if (booking.listing.images && booking.listing.images.length > 0) { %>
                                    <img src="<%= booking.listing.images[0].url %>" class="w-100 h-100 object-fit-cover hover-scale" alt="">
                                <% } else { %>
                                    <img src="[https://images.unsplash.com/photo-1499793983690-e29da59ef1c2](https://images.unsplash.com/photo-1499793983690-e29da59ef1c2)" class="w-100 h-100 object-fit-cover hover-scale" alt="">
                                <% } %>
                            </div>

                            <div class="px-2">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h5 class="fw-bold m-0 text-truncate" style="max-width: 75%;"><%= booking.listing.title %></h5>
                                    <span class="small text-muted fw-bold">#<%= booking._id.toString().slice(-5).toUpperCase() %></span>
                                </div>
                                <p class="text-muted small mb-3"><i class="fa-solid fa-location-dot me-1"></i> <%= booking.listing.location %></p>

                                <div class="date-info-box d-flex mb-3">
                                    <div class="flex-grow-1 text-center border-end">
                                        <small class="d-block text-uppercase extra-small fw-bold text-muted">Check-In</small>
                                        <span class="fw-bold"><%= booking.checkIn.toLocaleDateString('en-IN', {day: '2-digit', month: 'short'}) %></span>
                                    </div>
                                    <div class="flex-grow-1 text-center">
                                        <small class="d-block text-uppercase extra-small fw-bold text-muted">Check-Out</small>
                                        <span class="fw-bold"><%= booking.checkOut.toLocaleDateString('en-IN', {day: '2-digit', month: 'short'}) %></span>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div>
                                        <small class="d-block text-muted extra-small fw-bold">TOTAL PAID</small>
                                        <span class="fw-bold fs-5">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <a href="/listings/<%= booking.listing._id %>" class="ci-btn-reserve px-3 py-2 text-decoration-none small" style="font-size: 0.8rem;">View Stay</a>
                                    </div>
                                </div>

                                <form action="/bookings/<%= booking._id %>?_method=DELETE" method="POST" class="text-center">
                                    <button class="btn btn-link text-danger text-decoration-none extra-small fw-bold p-0" 
                                             onclick="return confirm('Cancel this reservation at <%= booking.listing.title %>?')">
                                        CANCEL RESERVATION
                                     </button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <% } %>
               <% } else { %>
                   <div class="col-12 text-center py-5 mt-5 animate-fade-in-up">
                       <div class="empty-state-box p-5 mx-auto" style="max-width: 500px; background: white; border-radius: 30px; border: 2px dashed #eee;">
                           <div class="mb-4">
                               <i class="fa-solid fa-suitcase-rolling text-muted" style="font-size: 4rem; opacity: 0.3;"></i>
                           </div>
                           <h4 class="fw-bold">No Upcoming Stays</h4>
                           <p class="text-muted">Your suitcase is empty. Start exploring the world's most unique sanctuaries and fill it with memories.</p>
                           <a href="/listings" class="ci-btn-reserve px-4 py-2 text-decoration-none d-inline-block mt-2">Explore Destinations</a>
                       </div>
                   </div>
               <% } %>
            </div>
        </div>

        <div class="tab-pane fade" id="past">
            <div class="text-center py-5 mt-5">
                <i class="fa-solid fa-clock-rotate-left mb-3 text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
                <h4 class="text-muted fw-bold">No Past Memories</h4>
                <p class="text-muted">Once you complete a stay, your photos and memories will appear here.</p>
            </div>
        </div>
    </div>
</div>
</div>

<style>
/* Custom Styles for Unified UI */
.premium-bg {
background-color: #fdfdfd;
}

.custom-pills .nav-link {
    color: #666;
    font-weight: 700;
    border-radius: 50px;
    padding: 10px 25px;
    transition: 0.3s;
    border: 1px solid transparent;
    margin: 0 5px;
}

.custom-pills .nav-link.active {
    background-color: #1a1a1a !important;
    color: #fff !important;
}

.custom-pills .nav-link:hover:not(.active) {
    border-color: #D38B5D;
    color: #D38B5D;
}

.booking-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(5px);
    padding: 4px 12px;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 800;
    z-index: 5;
    color: #1a1a1a;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.date-info-box {
    background: #f9f9f9;
    border-radius: 12px;
    padding: 10px 0;
}

.extra-small {
    font-size: 0.65rem;
    letter-spacing: 1px;
}

.hover-scale {
    transition: 0.5s ease;
}

.creative-info-card:hover .hover-scale {
    transform: scale(1.08);
}
</style>