<% layout("/layouts/boilerplate") %>

<style>
:root {
    --rv-bg: #ffffff;
    --rv-dark: #0A0A0B;
    --rv-gold: #D38B5D;
    --rv-shadow-soft: 0 4px 20px rgba(0,0,0,0.06);
    --rv-shadow-deep: 0 20px 50px rgba(0,0,0,0.15);
}

body {
    background-color: var(--rv-bg);
    color: var(--rv-dark);
    font-family: 'Manrope', sans-serif;
    overflow-x: hidden;
}

.vision-header {
    padding: 100px 0 40px;
}

.vision-eyebrow {
    text-transform: uppercase;
    letter-spacing: 5px;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--rv-gold);
    display: block;
    margin-bottom: 20px;
}

.vision-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -2px;
}

.dynamic-category-row {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 50px;
    overflow-x: auto;
    padding: 10px 20px;
    scrollbar-width: none;
}
.dynamic-category-row::-webkit-scrollbar { display: none; }

.category-pill-vision {
    padding: 10px 22px;
    border-radius: 100px;
    border: 1px solid rgba(0,0,0,0.1);
    text-decoration: none;
    color: #777;
    font-weight: 700;
    font-size: 0.8rem;
    white-space: nowrap;
    transition: 0.3s;
}

.category-pill-vision.active,
.category-pill-vision:hover {
    background: var(--rv-dark);
    color: #fff;
    border-color: var(--rv-dark);
}

/* ── Grid: 3 equal columns, no gaps ── */
.fluid-magazine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding-bottom: 100px;
}

/* Default: 1 of 3 columns */
.magazine-item { grid-column: span 1; }

/* Wide: 2 of 3 columns — always leaves exactly 1 col for the next card */
.magazine-item.wide { grid-column: span 2; }

/* Card link */
.vision-card {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
}

/* Frame — uniform height, no gaps */
.vision-frame {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    background: #e0e0e0;
    height: 340px;
    transition: transform 0.45s cubic-bezier(0.165, 0.84, 0.44, 1),
                box-shadow 0.45s ease;
}

.magazine-item.wide .vision-frame { height: 340px; }

.vision-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s ease;
    display: block;
}

.vision-card:hover .vision-img   { transform: scale(1.06); }
.vision-card:hover .vision-frame {
    transform: translateY(-4px);
    box-shadow: var(--rv-shadow-deep);
}

/* Gradient overlay — always visible */
.vision-meta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.1) 45%, transparent 65%);
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
}

.vision-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px 0;
    line-height: 1.3;
}

.magazine-item.wide .vision-card-title { font-size: 1.25rem; }

.vision-card-loc {
    color: rgba(255,255,255,0.72);
    font-size: 0.77rem;
    font-weight: 500;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 4px;
}

.vision-price-pill {
    position: absolute;
    top: 14px;
    right: 14px;
    background: #fff;
    padding: 5px 13px;
    border-radius: 100px;
    font-weight: 800;
    font-size: 0.82rem;
    box-shadow: var(--rv-shadow-soft);
    color: var(--rv-dark);
    white-space: nowrap;
}

.empty-state {
    grid-column: span 3;
    text-align: center;
    padding: 5rem 0;
    color: #aaa;
}

/* ── Responsive ── */
@media (max-width: 900px) {
    .fluid-magazine-grid { grid-template-columns: repeat(2, 1fr); }
    .magazine-item,
    .magazine-item.wide { grid-column: span 1; }
    .empty-state { grid-column: span 2; }
}

@media (max-width: 560px) {
    .fluid-magazine-grid { grid-template-columns: 1fr; }
    .magazine-item,
    .magazine-item.wide { grid-column: span 1; }
    .vision-frame,
    .magazine-item.wide .vision-frame { height: 260px; }
    .vision-header { padding: 70px 20px 20px; }
    .empty-state { grid-column: span 1; }
}
</style>

<div class="vision-header text-center">
    <div class="container">
        <span class="vision-eyebrow">Roavista Curated</span>
        <h1 class="vision-headline">The World.<br>In a New Light.</h1>
    </div>
</div>

<div class="dynamic-category-row">
    <%
        const categories = [
            'Trending','Rooms','Cities','Mountains',
            'Castles','Pools','Camping','Arctic','Boats'
        ];
    %>
    <a href="/listings" class="category-pill-vision <%= !locals.currentCategory ? 'active' : '' %>">All</a>
    <% categories.forEach(cat => { %>
        <a href="/listings?category=<%= cat %>"
           class="category-pill-vision <%= locals.currentCategory === cat ? 'active' : '' %>">
            <%= cat %>
        </a>
    <% }) %>
</div>

<div class="container-fluid px-lg-5">
    <div class="fluid-magazine-grid">
        <% if (!allListings || allListings.length === 0) { %>
            <div class="empty-state"><p>No listings found.</p></div>
        <% } else { %>
            <%
                /*
                 * Pattern per group of 3 cards:
                 *   index % 3 === 0 → wide (span 2)
                 *   index % 3 === 1 → normal (span 1)  ← sits beside the wide
                 *   index % 3 === 2 → normal (span 1) + normal (span 1) ... 
                 * 
                 * Actually simpler: alternate groups of [wide + narrow] then [narrow + narrow + narrow]
                 * Easiest reliable pattern: every 3rd card starting at 0 is wide.
                 * Group of 3: wide(2) + narrow(1) = 3 cols ✓
                 * Next group of 3: narrow(1) + narrow(1) + narrow(1) = 3 cols ✓
                 * Repeat. No gaps ever.
                 */
            %>
            <% allListings.forEach((listing, index) => {
                // Groups of 6: positions 0-5, 6-11, 12-17...
                // Within each group of 6:
                //   pos 0 → wide, pos 1 → narrow  (row 1: 2+1=3)
                //   pos 2,3,4 → narrow x3          (row 2: 1+1+1=3)
                //   pos 5 → wide ... wait, that breaks row 3
                // Simplest: every 4th card (0,4,8...) is wide, rest narrow
                // Group of 4: wide(2)+narrow(1)+narrow(1) ... but 2+1+1=4 cols on a 3-col grid → overflow
                //
                // CORRECT PATTERN for 3-col grid:
                // Group of 3 cards repeating:
                //   Card A: wide (span 2)
                //   Card B: narrow (span 1)   → A+B fill row (2+1=3) ✓
                //   Card C: narrow (span 1)
                //   ... but C alone on next row = gap
                //
                // CLEANEST: alternate rows
                //   Even rows (0,1): wide + narrow  (indices 0,1 → 2+1=3)
                //   Odd rows (2,3,4): narrow×3      (indices 2,3,4 → 1+1+1=3)
                // Pattern repeats every 5 cards.
                const pos = index % 5;
                const isWide = (pos === 0); // only index 0 of each 5-group is wide
                const itemClass = "magazine-item" + (isWide ? " wide" : "");
                const imgUrl = (listing.images && listing.images.length > 0)
                    ? listing.images[0].url
                    : "/images/placeholder.jpg";
            %>
                <div class="<%= itemClass %> stagger-reveal">
                    <a href="/listings/<%= listing._id %>" class="vision-card">
                        <div class="vision-frame">
                            <img src="<%= imgUrl %>"
                                 class="vision-img"
                                 loading="lazy"
                                 alt="<%= listing.title %>">

                            <span class="vision-price-pill">
                                ₹<%= listing.price.toLocaleString("en-IN") %>
                            </span>

                            <div class="vision-meta-overlay">
                                <h4 class="vision-card-title"><%= listing.title %></h4>
                                <p class="vision-card-loc">
                                    <i class="fa-solid fa-location-dot" style="font-size:10px"></i>
                                    <%= listing.location %>, <%= listing.country %>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            <% }) %>
        <% } %>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = "1";
                entry.target.style.transform = "translateY(0)";
            }
        });
    }, { threshold: 0.08 });

    document.querySelectorAll('.stagger-reveal').forEach((el, i) => {
        el.style.opacity = "0";
        el.style.transform = "translateY(35px)";
        el.style.transition = `opacity 0.65s ease ${i * 0.04}s, transform 0.65s cubic-bezier(0.165,0.84,0.44,1) ${i * 0.04}s`;
        observer.observe(el);
    });
});
</script>