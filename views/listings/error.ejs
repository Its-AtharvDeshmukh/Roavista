<% layout("/layouts/boilerplate") %>

<style>
    /* 1. LAYOUT - Removed custom background to show boilerplate original */
    .rv-error-section {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        font-family: 'Manrope', sans-serif;
    }

    .rv-error-card {
        /* Background removed to inherit parent/boilerplate color */
        padding: 4rem 2rem;
        max-width: 700px;
        width: 100%;
        text-align: center;
        animation: slideUp 0.6s ease-out;
    }

    /* 2. ICON & BRANDING */
    .rv-icon-circle {
        width: 80px;
        height: 80px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        box-shadow: 0 10px 20px rgba(196, 128, 90, 0.1);
        animation: float 4s ease-in-out infinite;
    }

    .rv-icon-circle i {
        font-size: 2.2rem;
        color: #C4805A; /* Your Gold Brand Color */
    }

    /* 3. TYPOGRAPHY */
    .rv-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.2rem, 5vw, 3.2rem);
        color: #1A1A1A;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .rv-msg-text {
        color: #6B7280;
        font-size: 1.15rem;
        line-height: 1.7;
        margin-bottom: 2.5rem;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }

    /* 4. CLEAR ACTION BUTTONS */
    .rv-btn-container {
        display: flex;
        gap: 15px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .rv-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 36px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .rv-btn-dark {
        background: #1A1A1A;
        color: white;
    }

    .rv-btn-dark:hover {
        background: #C4805A;
        transform: translateY(-3px);
        box-shadow: 0 12px 24px rgba(196, 128, 90, 0.2);
        color: white;
    }

    .rv-btn-outline {
        border: 1px solid #ddd;
        color: #1A1A1A;
        background: transparent;
    }

    .rv-btn-outline:hover {
        background: rgba(0,0,0,0.02);
        border-color: #1A1A1A;
    }

    /* 5. DEVELOPER SECTION */
    .rv-dev-section {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0,0,0,0.05);
    }

    .rv-dev-toggle {
        background: none;
        border: none;
        color: #B5B5B5;
        font-size: 0.75rem;
        letter-spacing: 1px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: underline;
        text-transform: uppercase;
    }

    .rv-stack-box {
        display: none;
        margin-top: 1.5rem;
        text-align: left;
        background: rgba(0,0,0,0.02);
        padding: 20px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        font-family: 'Fira Code', monospace;
        font-size: 0.8rem;
        color: #888;
        max-height: 250px;
        overflow-y: auto;
    }

    /* ANIMATIONS */
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-12px); }
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<section class="rv-error-section">
    <div class="rv-error-card">
        <div class="rv-icon-circle">
            <i class="fa-solid fa-compass-drafting"></i>
        </div>

        <h1 class="rv-title">Path Obscured.</h1>
        
        <p class="rv-msg-text">
            We encountered a temporary hurdle while loading your sanctuary. Please try returning to the collection or refreshing the page.
        </p>

        <div class="rv-btn-container">
            <a href="/listings" class="rv-btn rv-btn-dark">
                <i class="fa-solid fa-list-ul"></i> View Collection
            </a>
            <a href="javascript:location.reload()" class="rv-btn rv-btn-outline">
                <i class="fa-solid fa-rotate-right"></i> Reload Page
            </a>
        </div>

        <% if(process.env.NODE_ENV !== "production" && err.stack) { %>
            <div class="rv-dev-section">
                <button class="rv-dev-toggle" onclick="toggleStack()">
                    Analyze System Log
                </button>
                <div id="stackOutput" class="rv-stack-box">
                    <p style="margin-bottom: 10px; font-weight: 700; color: #555;">[DEVELOPER STACK TRACE]</p>
                    <pre style="margin: 0; white-space: pre-wrap;"><%= err.stack %></pre>
                </div>
            </div>
        <% } %>
    </div>
</section>

<script>
    function toggleStack() {
        const box = document.getElementById('stackOutput');
        box.style.display = (box.style.display === 'block') ? 'none' : 'block';
    }
</script>