       <div class="master-stack">
    <h4 class="stack-title">Built with Modern Technologies</h4>
    
    <div class="stack-ticker-wrapper">
        <div class="stack-ticker-inner">
            <% 
               const techStack = [
                 { name: 'Node.js Runtime', icon: 'fa-node-js', isBrand: true },
                 { name: 'Express Framework', icon: 'fa-server', isBrand: false },
                 { name: 'MongoDB Atlas', icon: 'fa-database', isBrand: false },
                 { name: 'Passport.js Auth', icon: 'fa-shield-halved', isBrand: false },
                 { name: 'Google OAuth 2.0', icon: 'fa-google', isBrand: true },
                 { name: 'Render Deployment', icon: 'fa-cloud-arrow-up', isBrand: false },
                 { name: 'Cloudinary Storage', icon: 'fa-cloud', isBrand: false },
                 { name: 'Mapbox SDK', icon: 'fa-map-location-dot', isBrand: false },
                 { name: 'Bootstrap 5', icon: 'fa-bootstrap', isBrand: true },
                 { name: 'EJS-Mate Engine', icon: 'fa-code', isBrand: false },
                 { name: 'Connect-Flash', icon: 'fa-envelope-open-text', isBrand: false },
                 { name: 'Joi Validation', icon: 'fa-file-code', isBrand: false }
               ];
            %>
            
            <% techStack.forEach(tech => { %>
                <div class="stack-pill">
                    <i class="<%= tech.isBrand ? 'fa-brands' : 'fa-solid' %> <%= tech.icon %>"></i> 
                    <%= tech.name %>
                </div>
            <% }) %>

            <% techStack.forEach(tech => { %>
                <div class="stack-pill" aria-hidden="true">
                    <i class="<%= tech.isBrand ? 'fa-brands' : 'fa-solid' %> <%= tech.icon %>"></i> 
                    <%= tech.name %>
                </div>
            <% }) %>

        </div>
    </div>
