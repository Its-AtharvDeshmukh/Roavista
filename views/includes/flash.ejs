<style>
    /* ============================================================
       THE DYNAMIC ISLAND FLASH (Ultra-Premium UI)
       ============================================================ */
    .rv-flash-hub {
        position: fixed;
        top: 85px; /* Sits nicely under your navbar */
        left: 50%;
        transform: translateX(-50%);
        z-index: 100000;
        display: flex;
        flex-direction: column;
        gap: 12px;
        pointer-events: none;
        width: 90%;
        /* 👇 CHANGED THIS: Increased from 400px to 600px */
        max-width: 500px; 
    }

    .rv-dynamic-pill {
        pointer-events: auto; 
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 100px;
        padding: 8px 24px 8px 8px; /* Extra right padding, snug left */
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1), 0 0 0 1px rgba(0,0,0,0.03);
        cursor: pointer;
        margin-top: 40px;
        /* Spring Animation */
        animation: islandDrop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        transition: opacity 0.3s ease, transform 0.3s ease, scale 0.15s ease;
    }

    .rv-dynamic-pill:active {
        scale: 0.95;
    }

    .flash-orb {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
        box-shadow: inset 0 2px 4px rgba(255,255,255,0.5);
    }

    /* Success Styling */
    .pill-success .flash-orb { background: #10B981; color: white; }
    
    /* Error Styling */
    .pill-error .flash-orb { background: #EF4444; color: white; }

    .flash-message-text {
        font-family: 'Manrope', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #111;
        margin: 0;
        line-height: 1.3;
    }

    @keyframes islandDrop {
        0% { opacity: 0; transform: translateY(-40px) scale(0.8); }
        100% { opacity: 1; transform: translateY(0) scale(1); }
    }

    .pill-dismissed {
        opacity: 0 !important;
        transform: translateY(-20px) scale(0.9) !important;
    }
</style>

<div class="rv-flash-hub">
    <% if(success && success.length) { %>
        <div class="rv-dynamic-pill pill-success" onclick="dismissFlash(this)">
            <div class="flash-orb">
                <i class="fa-solid fa-check"></i>
            </div>
            <p class="flash-message-text"><%= success %></p>
        </div>
    <% } %>

    <% if(error && error.length) { %>
        <div class="rv-dynamic-pill pill-error" onclick="dismissFlash(this)">
            <div class="flash-orb">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>
            <p class="flash-message-text"><%= error %></p>
        </div>
    <% } %>
</div>

<script>
    // Smooth dismiss function
    function dismissFlash(element) {
        element.classList.add('pill-dismissed');
        setTimeout(() => element.remove(), 300); 
    }

    // Auto-hide after 4 seconds
    document.addEventListener("DOMContentLoaded", () => {
        const pills = document.querySelectorAll('.rv-dynamic-pill');
        pills.forEach(pill => {
            setTimeout(() => {
                if(document.body.contains(pill)) { dismissFlash(pill); }
            }, 4000);
        });
    });
</script>