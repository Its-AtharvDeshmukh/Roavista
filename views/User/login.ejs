<% layout("/layouts/boilerplate") %>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&display=swap');

    </style>

<div class="auth-wrapper">
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>

    <div class="container d-flex justify-content-center align-items-center auth-container">
        <div class="auth-card shadow-lg">
            <div class="auth-header text-center">
                <div class="auth-icon-circle mx-auto mb-3"><i class="fa-solid fa-key"></i></div>
                <h2 class="auth-title">Welcome back</h2>
                <p class="auth-subtitle">Continue your journey with Roavista.</p>
            </div>

            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="input-group-custom mb-4">
                    <div class="input-icon"><i class="fa-regular fa-user"></i></div>
                    <input type="text" name="username" class="form-control auth-input" placeholder="Username" required>
                </div>
                <div class="input-group-custom mb-4">
                    <div class="input-icon"><i class="fa-solid fa-lock"></i></div>
                    <input type="password" name="password" class="form-control auth-input" placeholder="Password" required>
                </div>
                <button class="btn btn-auth w-100 mb-3">Log In</button>
            </form>

            <div class="auth-divider"><span>or</span></div>

            <a href="/auth/google" class="btn btn-social w-100 mb-4">
                <img src="https://cdn-icons-png.flaticon.com/512/2991/2991148.png" alt="Google" class="social-icon">
                Continue with Google
            </a>

            <p class="text-center m-0 mt-4 small text-muted">
                Don't have an account? <a href="/signup" class="auth-link">Join Roavista</a>
            </p>
        </div>
    </div>
</div>